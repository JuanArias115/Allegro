# ============================================================
# Allegro — variables de entorno de ejemplo
# Copia este archivo a `.env` y ajusta los valores.
# NUNCA pongas credenciales reales en el repositorio.
# ============================================================

# ----- PostgreSQL -----
POSTGRES_DB=allegro
POSTGRES_USER=allegro
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_PORT=5432

# ----- Backend (.NET) -----
# Cadena de conexión usada por la API (el host "db" es el servicio de compose).
ConnectionStrings__Default=Host=db;Port=5432;Database=allegro;Username=allegro;Password=change_me_local_only
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8080

# Aplicar migraciones automáticamente al iniciar (recomendado en local).
APPLY_MIGRATIONS=true
# Sembrar datos de demostración. SOLO debe ser true en desarrollo.
SEED_DEMO_DATA=true

# ----- Autenticación -----
# AUTH_MODE = firebase | local
#   firebase -> valida tokens reales de Firebase Authentication.
#   local    -> modo desarrollo: acepta un token de desarrollo. NUNCA en producción.
AUTH_MODE=local
# ID del proyecto de Firebase (requerido cuando AUTH_MODE=firebase).
FIREBASE_PROJECT_ID=
# Token estático aceptado solo en AUTH_MODE=local (cabecera: Authorization: Bearer <token>).
LOCAL_DEV_TOKEN=allegro-dev-token
