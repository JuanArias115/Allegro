# ============================================================
# Allegro — variables de PRODUCCIÓN (ejemplo)
# Copia este archivo a /opt/allegro/.env en el servidor y completa los valores.
# NUNCA subas el .env real ni credenciales a Git.
# ============================================================

# Imagen a desplegar. El pipeline la fija al SHA del commit; 'latest' por defecto.
IMAGE_TAG=latest

# ----- PostgreSQL (servicio allegro-db) -----
POSTGRES_DB=allegro
POSTGRES_USER=allegro
POSTGRES_PASSWORD=__define_un_password_fuerte__

# ----- API (.NET) -----
# Cadena de conexión. El host es el nombre del servicio de base de datos.
ConnectionStrings__Default=Host=allegro-db;Port=5432;Database=allegro;Username=allegro;Password=__el_mismo_password__

# Aplicar migraciones al iniciar (idempotente). Recomendado: true.
APPLY_MIGRATIONS=true

# ----- Autenticación (Firebase) -----
# En producción AUTH_MODE debe ser 'firebase'. 'local' está PROHIBIDO
# (el backend se niega a arrancar en Production con AUTH_MODE=local).
AUTH_MODE=firebase
# ID del proyecto de Firebase (valida los tokens contra Google).
FIREBASE_PROJECT_ID=allegro-95408
# El archivo de Firebase Admin debe existir únicamente en el servidor en:
# /opt/allegro/secrets/firebase-admin.json (permisos 600).

# Zona horaria del negocio (para el cálculo de "hoy").
BUSINESS_TIMEZONE=America/Bogota

# ----- Web administrativa (configuración pública Firebase Web) -----
ADMIN_IMAGE_TAG=latest
ADMIN_API_BASE_URL=https://allegro.juanariasdev.com
GOOGLE_AUTH_ENABLED=true
FIREBASE_WEB_API_KEY=__firebase_web_api_key__
FIREBASE_WEB_AUTH_DOMAIN=allegro-95408.firebaseapp.com
FIREBASE_WEB_PROJECT_ID=allegro-95408
FIREBASE_WEB_STORAGE_BUCKET=allegro-95408.firebasestorage.app
FIREBASE_WEB_MESSAGING_SENDER_ID=54207387771
FIREBASE_WEB_APP_ID=__firebase_web_app_id__

# Origen permitido por CORS para Angular.
Cors__AllowedOrigins__0=https://admin.allegro.juanariasdev.com
